{
  "name": "@ac/acp-session-manager",
  "version": "0.2.0",
  "description": "OpenClaw Plugin for ACP session management with approval surfacing",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "prepack": "npm run clean && npm run build"
  },
  "dependencies": {
    "2": "^3.0.0",
    "@sinclair/typebox": "^0.32.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.4.0"
  },
  "files": [
    "dist",
    "openclaw.plugin.json",
    "README.md"
  ],
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ],
    "install": {
      "npmSpec": "@ac/acp-session-manager",
      "defaultChoice": "npm",
      "minHostVersion": ">=2026.5.28"
    },
    "compat": {
      "pluginApi": ">=2026.5.28"
    }
  }
}
